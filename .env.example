# Шаблон переменных окружения. Скопировать в .env и заполнить.
# .env в .gitignore и в репозиторий не попадает.

KWORK_LOGIN=
KWORK_PASSWORD=

# Второй аккаунт — опционально, для живых тестов сообщений между своими аккаунтами:
KWORK_LOGIN2=
KWORK_PASSWORD2=

# Извлекается из APK при захвате (Фаза 1):
KWORK_APP_AUTHORIZATION=
KWORK_USER_AGENT=
